# ── Dependencies ────────────────────────────────────────────────
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js (frontend) ──────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/next-env.d.ts

# ── Backend build ────────────────────────────────────────────────
backend/dist/

# ── Environment files (never commit secrets) ─────────────────────
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local
backend/.env
backend/.env.local
backend/.env.*.local

# ── TypeScript build info ────────────────────────────────────────
*.tsbuildinfo

# ── Coverage / testing ───────────────────────────────────────────
coverage/

# ── Misc ─────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel

# ── Debug logs ───────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Local-only files (not for repo) ─────────────────────────────
make_commits.sh
DEPLOYMENT.md
